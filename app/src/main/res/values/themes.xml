<?xml version="1.0" encoding="utf-8"?>
<!-- 主题 — Material Design 3 商业级样式 -->
<resources>
    <!-- ===== 基础主题（亮色）===== -->
    <style name="Theme.SmartTravel" parent="Theme.Material3.Light.NoActionBar">
        <!-- MD3 颜色 -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>
        <item name="colorPrimaryContainer">@color/md_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/md_on_primary_container</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorSecondaryContainer">@color/md_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/md_on_secondary_container</item>
        <item name="colorTertiary">@color/md_tertiary</item>
        <item name="colorTertiaryContainer">@color/md_tertiary_container</item>
        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/md_on_surface_variant</item>
        <item name="colorError">@color/md_error</item>
        <item name="colorOutline">@color/md_outline</item>
        <item name="colorOutlineVariant">@color/md_outline_variant</item>

        <!-- 状态栏 — 透明沉浸式 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/md_surface</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- 组件样式 -->
        <item name="bottomNavigationStyle">@style/Widget.SmartTravel.BottomNavigation</item>
        <item name="materialCardViewStyle">@style/Widget.SmartTravel.Card</item>

        <!-- 页面切换动画 -->
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <!-- ===== BottomNavigation 圆角导航栏 ===== -->
    <style name="Widget.SmartTravel.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/md_surface</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.SmartTravel.NavIndicator</item>
        <item name="itemIconTint">@color/nav_unselected</item>
        <item name="itemTextColor">@color/nav_unselected</item>
        <item name="elevation">12dp</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemRippleColor">@color/md_primary_container</item>
    </style>

    <!-- 导航选中指示器 -->
    <style name="Widget.SmartTravel.NavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/md_primary_container</item>
        <item name="android:width">24dp</item>
        <item name="android:height">24dp</item>
    </style>

    <!-- ===== 卡片样式 ===== -->
    <style name="Widget.SmartTravel.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="contentPadding">@dimen/padding_card</item>
        <item name="cardBackgroundColor">@color/md_surface</item>
    </style>

    <!-- ===== 启动画面主题 ===== -->
    <style name="Theme.Splash" parent="Theme.SmartTravel">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
