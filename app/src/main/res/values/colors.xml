    <color name="md_primary">#FF1677FF</color>
    <color name="md_primary_light">#FF409EFF</color>
    <color name="md_primary_dark">#FF0954C5</color>
    <color name="md_on_primary">#FFFFFFFF</color>
    <color name="md_primary_container">#FFD6EAFF</color>
