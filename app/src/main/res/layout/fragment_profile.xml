<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_profile.xml - 个人中心页面（升级版）
     顶部：头像 + 昵称 + UID + 会员徽章
     统计行：3 张渐变卡片（订单/消费/减碳）
     菜单列表：历史订单/优惠券/设置/关于系统/数据分析中心/帮助与反馈 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== 头部资料区 ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/md_primary"
                android:paddingTop="40dp"
                android:paddingBottom="28dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <!-- 头像 -->
                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/bg_avatar_placeholder"
                    android:importantForAccessibility="no" />

                <!-- 用户名 -->
                <TextView
                    android:id="@+id/tv_profile_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="默认用户"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- 用户 ID -->
                <TextView
                    android:id="@+id/tv_profile_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="ID: 202315103070"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:alpha="0.7" />

                <!-- 会员徽章 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/tv_profile_vip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="黄金会员"
                    android:textColor="#8B5E00"
                    android:textSize="12sp"
                    android:backgroundTint="#FFD700"
                    app:cornerRadius="12dp"
                    app:icon="@null"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:minHeight="0dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="2dp"
                    android:importantForAccessibility="no" />

            </LinearLayout>

            <!-- ===== 统计卡片行（3 列） ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginTop="-20dp">

                <!-- 订单统计 -->
                <LinearLayout
                    android:id="@+id/layout_stat_orders"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_gradient_blue"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_order"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:id="@+id/tv_profile_orders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="12"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="订单"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:alpha="0.85" />
                </LinearLayout>

                <!-- 消费统计 -->
                <LinearLayout
                    android:id="@+id/layout_stat_spending"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_gradient_green"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_coupon"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:id="@+id/tv_profile_spending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="¥2,580"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="消费"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:alpha="0.85" />
                </LinearLayout>

                <!-- 减碳统计 -->
                <LinearLayout
                    android:id="@+id/layout_stat_carbon"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_gradient_orange"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_carbon"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:id="@+id/tv_profile_carbon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="85kg"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="减碳"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:alpha="0.85" />
                </LinearLayout>

            </LinearLayout>

            <!-- ===== 功能菜单列表 ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="16dp">

                <!-- 历史订单 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/md_surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_car_1"
                            android:importantForAccessibility="no" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="历史订单"
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp" />
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_right"
                            android:alpha="0.3"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 优惠券 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_coupon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/md_surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_coupon"
                            android:importantForAccessibility="no" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="优惠券"
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp" />
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_right"
                            android:alpha="0.3"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 数据分析中心（ID 保持兼容） -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_statistics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/md_surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_order"
                            android:importantForAccessibility="no" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="数据分析中心"
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="出行/碳排/运营"
                            android:textSize="11sp"
                            android:textColor="@color/color_text_hint"
                            android:layout_marginEnd="6dp" />
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_right"
                            android:alpha="0.3"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 设置 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/md_surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_settings"
                            android:importantForAccessibility="no" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="设置"
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp" />
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_right"
                            android:alpha="0.3"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 关于系统 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_about"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/md_surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_info"
                            android:importantForAccessibility="no" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="关于系统"
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp" />
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_right"
                            android:alpha="0.3"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 帮助与反馈 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_help"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/md_surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_info"
                            android:importantForAccessibility="no" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="帮助与反馈"
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp" />
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_right"
                            android:alpha="0.3"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
