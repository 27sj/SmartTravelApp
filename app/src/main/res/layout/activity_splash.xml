<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     activity_splash.xml — 启动画面布局
     深蓝渐变背景 + 应用图标 + 学院班级姓名信息
     ============================================================ -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splash_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_primary">

    <!-- 中央区域：应用图标 + 名称 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0.95"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tv_info"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 应用图标 -->
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="应用图标"
            android:elevation="4dp" />

        <!-- 应用名称 -->
        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/app_name"
            android:textColor="@color/color_white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <!-- 副标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="智慧出行打车系统"
            android:textColor="@color/md_primary_container"
            android:textSize="14sp"
            android:letterSpacing="0.03" />

    </LinearLayout>

    <!-- 底部信息：学院 + 班级 + 姓名 -->
    <TextView
        android:id="@+id/tv_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="交通工程学院 智通232 孙季琛"
        android:textColor="@color/md_primary_container"
        android:textSize="14sp"
        android:letterSpacing="0.03"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 底部版权信息 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="课程设计演示应用"
        android:textColor="#55FFFFFF"
        android:textSize="11sp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
