<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     activity_car_select.xml — 车型选择页
     RecyclerView 展示四种车型，每项包含图标/名称/时间/价格
     顶部：返回按钮 + 标题
     ============================================================ -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <!-- 顶部工具栏 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/md_surface"
        app:elevation="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/select_car_title"
        app:titleTextColor="@color/color_text_primary"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationContentDescription="@string/back" />

    <!-- 起点→终点信息 -->
    <LinearLayout
        android:id="@+id/layout_route_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_medium"
        android:background="@color/md_surface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <TextView
            android:id="@+id/tv_start_point"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/my_location"
            android:textColor="@color/color_text_primary"
            android:textSize="15sp"
            android:drawableStart="@drawable/ic_location_on"
            android:drawablePadding="8dp" />
        <TextView
            android:id="@+id/tv_end_point"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/color_text_secondary"
            android:textSize="14sp"
            android:drawableStart="@drawable/ic_location_target"
            android:drawablePadding="8dp" />
    </LinearLayout>

    <!-- 车型列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_car_types"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/margin_medium"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_route_info" />

</androidx.constraintlayout.widget.ConstraintLayout>
