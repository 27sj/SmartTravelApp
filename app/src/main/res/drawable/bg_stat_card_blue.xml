<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF161B2B"/>
            <stroke android:width="1dp" android:color="#FF1E2640"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item android:width="3dp" android:gravity="left">
        <shape android:shape="rectangle">
            <solid android:color="@color/stat_accent_blue"/>
            <corners android:topLeftRadius="16dp" android:bottomLeftRadius="16dp"/>
        </shape>
    </item>
</layer-list>
